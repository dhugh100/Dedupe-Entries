void print_msg(const char *str)
{
	time_t now;
	struct tm result;
	char buffer[26];

	now = time(NULL); // Get UNIX-style time since epoc
     	localtime_r(&now, &result); // Convert to broken down time in result
    	strftime(buffer, 26, "%Y-%m-%d %H:%M:%S", result); // format time in buffer
	printf("%s: %s\n", buffer, str); // print buffer and string
}

